# =============================================================================
# WaveKit .gitignore — pnpm Monorepo + Turborepo
# =============================================================================

# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
node_modules/
.pnpm-store/
package-lock.json

# -----------------------------------------------------------------------------
# Build Outputs
# -----------------------------------------------------------------------------
dist/
*.tsbuildinfo

# -----------------------------------------------------------------------------
# Turborepo Cache
# -----------------------------------------------------------------------------
.turbo/

# Local Docker build cache exports (BuildKit)
.docker-cache/

# -----------------------------------------------------------------------------
# Environment & Secrets
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.pem

# -----------------------------------------------------------------------------
# IDE & Editors
# -----------------------------------------------------------------------------
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# OS Files
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
*.log

# -----------------------------------------------------------------------------
# Testing & Coverage
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
*.lcov

# -----------------------------------------------------------------------------
# Project-Specific: Runtime Data
# -----------------------------------------------------------------------------
decoded_calls/
debug_audio/
debug_iq_output/
output/
logs/
snapshots/

# -----------------------------------------------------------------------------
# Project-Specific: Development
# -----------------------------------------------------------------------------
wip/
demod_comparison_*/

# -----------------------------------------------------------------------------
# Project-Specific: Fixtures (downloaded/generated)
# -----------------------------------------------------------------------------
fixtures/raw/
fixtures/processed/

