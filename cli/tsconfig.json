{
	"compilerOptions": {
		"outDir": "./dist",
		"rootDir": "./source",
		"jsx": "react-jsx",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"target": "ES2022",
		"lib": ["ES2022"],
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"noPropertyAccessFromIndexSignature": false,
		"noUncheckedIndexedAccess": false
	},
	"include": ["source/**/*"],
	"exclude": ["node_modules", "dist"]
}

