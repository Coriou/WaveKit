{
	"name": "@wavekit/cli",
	"version": "1.0.0",
	"description": "WaveKit CLI Dashboard - Interactive terminal UI for monitoring",
	"type": "module",
	"bin": {
		"wavekit": "./dist/cli.js"
	},
	"scripts": {
		"build": "pnpm --filter @wavekit/api-types build && pnpm -w exec tsc -p cli/tsconfig.json",
		"dev": "pnpm -w exec tsc -p cli/tsconfig.json --watch",
		"lint": "eslint -c ../eslint.config.js .",
		"start": "node ./dist/cli.js",
		"test": "vitest run --passWithNoTests",
		"typecheck": "pnpm -w exec tsc -p cli/tsconfig.json --noEmit"
	},
	"dependencies": {
		"@wavekit/api-types": "workspace:*",
		"ink": "^5.1.0",
		"react": "^18.3.1",
		"ws": "^8.18.0"
	},
	"devDependencies": {
		"@types/node": "^25.0.3",
		"@types/react": "^18.3.18",
		"@types/ws": "^8.5.14",
		"typescript": "^5.9.3",
		"vitest": "^3.2.4"
	},
	"engines": {
		"node": ">=20"
	}
}
