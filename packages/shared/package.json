{
	"name": "@wavekit/shared",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "pnpm -w exec tsc -p packages/shared/tsconfig.json",
		"typecheck": "pnpm -w exec tsc -p packages/shared/tsconfig.json --noEmit",
		"lint": "eslint -c ../../eslint.config.js .",
		"test": "vitest run --passWithNoTests"
	},
	"dependencies": {
		"pino": "^9.7.0",
		"pino-pretty": "^13.0.0",
		"zod": "^3.25.67"
	},
	"devDependencies": {
		"@types/node": "^25.0.3",
		"typescript": "^5.9.3",
		"vitest": "^3.2.4"
	}
}
