{
	"name": "@wavekit/sdr-host",
	"version": "1.0.0",
	"private": true,
	"description": "RTL-SDR dongle host with rtlmux fanout and status API",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "pnpm -w exec tsc -p packages/sdr-host/tsconfig.build.json",
		"typecheck": "pnpm -w exec tsc -p packages/sdr-host/tsconfig.json --noEmit",
		"lint": "eslint -c ../../eslint.config.js .",
		"test": "vitest run --passWithNoTests",
		"start": "node ./dist/index.js"
	},
	"dependencies": {
		"@wavekit/shared": "workspace:*",
		"@fastify/cors": "^11.0.1",
		"fastify": "^5.3.3",
		"pino": "^9.7.0",
		"pino-pretty": "^13.0.0",
		"zod": "^3.25.67"
	},
	"devDependencies": {
		"@types/node": "^25.0.3",
		"typescript": "^5.9.3",
		"vitest": "^3.2.4"
	},
	"engines": {
		"node": ">=20"
	}
}
